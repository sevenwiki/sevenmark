{
  "name": "sevenmark",
  "displayName": "SevenMark",
  "description": "Language support for SevenMark wiki markup",
  "version": "0.1.0",
  "publisher": "sevenwiki",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/sevenwiki/sevenmark"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "sevenmark",
    "wiki",
    "markup",
    "language-server"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "main": "./dist/extension.js",
  "activationEvents": [
    "onLanguage:sevenmark"
  ],
  "scripts": {
    "postinstall": "cd client && pnpm i",
    "compile": "npm run check-types && node esbuild.js --production",
    "check-types": "tsc --noEmit",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^22.19.11",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.24.2",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3"
  },
  "contributes": {
    "languages": [
      {
        "id": "sevenmark",
        "aliases": [
          "SevenMark",
          "sevenmark"
        ],
        "extensions": [
          ".sm"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/sevenmark.png",
          "dark": "./icons/sevenmark.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "sevenmark",
        "scopeName": "source.sevenmark",
        "path": "./syntaxes/sevenmark.tmLanguage.json"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "SevenMark",
      "properties": {
        "sevenmark.server.path": {
          "type": "string",
          "default": "",
          "description": "Path to the sevenmark_language_server binary. If empty, looks for it on PATH."
        },
        "sevenmark.trace.server": {
          "type": "string",
          "scope": "window",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "enumDescriptions": [
            "No traces",
            "Error only",
            "Full log"
          ],
          "default": "off",
          "description": "Traces the communication between VS Code and the language server."
        }
      }
    },
    "configurationDefaults": {
      "[sevenmark]": {
        "editor.semanticHighlighting.enabled": true,
        "editor.minimap.renderCharacters": false
      }
    },
  }
}
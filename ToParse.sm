    [[공군 - {{{ #dark="padding: 2px 5px; border-radius: 5px; display: inline; background: #006f94" #style="padding: 2px 5px; border-radius: 5px; display: inline; background: #009dd1" || [[#file="대령 계급장.svg" width=30]]}}}, {{{ #dark="padding: 2px 5px; border-radius: 5px; display: inline; background: #006f94" #style="padding: 2px 5px; border-radius: 5px; display: inline; background: #009dd1" || [[#file="중령 계급장.svg" width=30&height=18]]}}}]]
  }}}]]
